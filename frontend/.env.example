# Kadamba frontend environment (Vite — baked in at build time)
# In production (Render Static Site / Vercel) set these in the project
# dashboard, then redeploy. Never commit a real .env.

# Backend API base URL. Production example (Render Web Service):
# VITE_API_URL=https://kadamba-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Display name (available to the app; used in metadata helpers)
VITE_APP_NAME=Kadamba's Designer Studio

# Canonical site origin — must match the live frontend origin (no trailing slash)
# Local: http://localhost:5173
# Current Render static site: https://kadamba-3lc7.onrender.com
# Custom domain later: https://kadambastudio.com
VITE_SITE_URL=http://localhost:5173

# Optional: enables the offline demo-admin unlock. DEV builds only; never set
# to true for a production build.
# VITE_ENABLE_DEMO_ADMIN=true
