# ─────────────────────────────────────────────────────────────
# Kadamba backend environment
# Copy to .env for local dev. In production (Render) set these in
# the dashboard. Values marked REQUIRED must be present in production
# or the server refuses to start.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000                       # Render injects PORT automatically; do not override there
NODE_ENV=development            # set to "production" on Render
FRONTEND_URL=http://localhost:5173
# Production: comma-separated https origins, no trailing slash, e.g.
# FRONTEND_URL=https://kadambastudio.com,https://www.kadambastudio.com

# Number of proxy hops to trust (Render/Vercel LB). Prod default is 1.
TRUST_PROXY=0

# Logging: error | warn | info | debug
LOG_LEVEL=debug

# Database — REQUIRED (use MongoDB Atlas in production)
MONGODB_URI=mongodb://localhost:27017/kadamba

# Auth — REQUIRED. JWT_SECRET must be >= 32 random chars in production.
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=1h

# Cloudinary — REQUIRED in production (local disk uploads are not durable on Render)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (Nodemailer) — required for contact/lead notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="Kadamba Studio <your_email@example.com>"
EMAIL_TO=studio@example.com     # admin inbox for form notifications

# First-admin bootstrap (used only by `npm run seed:admin`, then unset)
ADMIN_NAME=Studio Admin
ADMIN_EMAIL=admin@kadambastudio.com
ADMIN_PASSWORD=Kadamba@9898
